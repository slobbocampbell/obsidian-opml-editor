    "builtin-modules": "^4.0.0",
    "esbuild": "0.28.1",
    "obsidian": "1.13.1",
    "tslib": "^2.6.0",
    "typescript": "5.7.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
